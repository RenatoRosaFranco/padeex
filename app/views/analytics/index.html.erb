<div class="dash-welcome">
  <p class="dash-welcome-eyebrow">Analytics</p>
  <h1 class="dash-welcome-title">Dashboard de Métricas</h1>
  <p class="dash-welcome-sub">Visão geral das métricas da plataforma (dados mockados).</p>
</div>

<div class="analytics-grid">
  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-people-fill"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">2.847</span>
      <span class="analytics-stat-label">Usuários ativos</span>
      <span class="analytics-stat-change positive">+12% vs mês anterior</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-calendar-event"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">156</span>
      <span class="analytics-stat-label">Partidas realizadas</span>
      <span class="analytics-stat-change positive">+8% vs mês anterior</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-trophy-fill"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">23</span>
      <span class="analytics-stat-label">Torneios ativos</span>
      <span class="analytics-stat-change neutral">0% vs mês anterior</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-building-fill"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">89</span>
      <span class="analytics-stat-label">Clubes cadastrados</span>
      <span class="analytics-stat-change positive">+15% vs mês anterior</span>
    </div>
  </div>
</div>

<div class="analytics-charts">
  <div class="analytics-card analytics-card-chart">
    <h3 class="analytics-chart-title">Partidas por semana</h3>
    <div class="analytics-chart-mock">
      <div class="analytics-bar" style="height: 40%"></div>
      <div class="analytics-bar" style="height: 65%"></div>
      <div class="analytics-bar" style="height: 45%"></div>
      <div class="analytics-bar" style="height: 80%"></div>
      <div class="analytics-bar" style="height: 55%"></div>
      <div class="analytics-bar" style="height: 90%"></div>
      <div class="analytics-bar" style="height: 70%"></div>
    </div>
    <div class="analytics-chart-labels">
      <span>Seg</span>
      <span>Ter</span>
      <span>Qua</span>
      <span>Qui</span>
      <span>Sex</span>
      <span>Sáb</span>
      <span>Dom</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-chart">
    <h3 class="analytics-chart-title">Novos usuários (últimos 7 dias)</h3>
    <div class="analytics-chart-mock analytics-chart-line">
      <svg viewBox="0 0 300 80" class="analytics-line-chart">
        <polyline fill="none" stroke="rgba(74, 222, 128, 0.8)" stroke-width="2" points="0,60 40,55 80,45 120,50 160,35 200,30 240,25 280,20 300,18"/>
      </svg>
    </div>
  </div>
</div>

