<div class="ob-wizard" data-controller="onboarding-form">
  <%= render "onboarding/shared/progress", current_step: 1 %>

  <div class="ob-card">
    <div class="ob-card__icon"><i class="bi bi-person-fill"></i></div>
    <h1 class="ob-card__title">Dados pessoais</h1>
    <p class="ob-card__sub">Precisamos de algumas informações básicas para personalizar sua experiência.</p>

    <% if current_user.errors.any? %>
      <div class="ob-alert ob-alert--error">
        <% current_user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: current_user, url: onboarding_personal_info_path, method: :patch, class: "ob-form" do |f| %>
      <div class="ob-field">
        <%= f.label :name, "Nome completo", class: "ob-label" %>
        <%= f.text_field :name, class: "ob-input", placeholder: "João Silva", autofocus: true, autocomplete: "name" %>
      </div>

      <div class="ob-field">
        <%= f.label :mobile_number, "Telefone", class: "ob-label" %>
        <%= f.telephone_field :mobile_number, class: "ob-input", placeholder: "(11) 99999-9999",
              inputmode: "numeric", autocomplete: "tel",
              data: { action: "input->onboarding-form#formatPhone" } %>
      </div>

      <div class="ob-field">
        <%= f.label :cpf, "CPF", class: "ob-label" %>
        <%= f.text_field :cpf, class: "ob-input", placeholder: "000.000.000-00", inputmode: "numeric",
              data: { action: "input->onboarding-form#formatCpf" } %>
      </div>

      <button type="submit" class="ob-btn ob-btn--primary">
        Continuar <i class="bi bi-arrow-right"></i>
      </button>
    <% end %>
  </div>
</div>
