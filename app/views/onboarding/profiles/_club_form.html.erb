<div class="ob-card" data-controller="onboarding-form">
  <div class="ob-card__icon"><i class="bi bi-building-fill"></i></div>
  <h1 class="ob-card__title">Perfil do clube</h1>
  <p class="ob-card__sub">Apresente seu clube para a comunidade Padeex.</p>

  <% if @profile.errors.any? %>
    <div class="ob-alert ob-alert--error">
      <% @profile.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @profile, url: onboarding_profile_path, method: :patch,
        multipart: true, class: "ob-form" do |f| %>
    <div class="ob-field">
      <%= f.label :logo, "Logo do clube", class: "ob-label" %>
      <%= f.file_field :logo, class: "ob-input ob-file", accept: "image/*" %>
    </div>

    <div class="ob-row-fields">
      <div class="ob-field">
        <%= f.label :club_name, "Nome do clube", class: "ob-label" %>
        <%= f.text_field :club_name, class: "ob-input", placeholder: "Arena Padel SP" %>
      </div>

      <div class="ob-field">
        <%= f.label :cnpj, "CNPJ", class: "ob-label" %>
        <%= f.text_field :cnpj, class: "ob-input", placeholder: "00.000.000/0001-00", inputmode: "numeric",
              data: { action: "input->onboarding-form#formatCnpj" } %>
      </div>
    </div>

    <div class="ob-field">
      <%= f.label :address, "Endereço", class: "ob-label" %>
      <%= f.text_field :address, class: "ob-input", placeholder: "Rua Exemplo, 100 – Bairro, Cidade – SP",
            autocomplete: "off",
            data: {
              controller: "places-autocomplete",
              "places-autocomplete-api-key-value": google_maps_api_key
            } %>
    </div>

    <div class="ob-row-fields">
      <div class="ob-field">
        <%= f.label :phone, "Telefone", class: "ob-label" %>
        <%= f.telephone_field :phone, class: "ob-input", placeholder: "(11) 99999-9999", inputmode: "numeric",
              data: { action: "input->onboarding-form#formatPhone" } %>
      </div>

      <div class="ob-field">
        <%= f.label :email, "E-mail do clube", class: "ob-label" %>
        <%= f.email_field :email, class: "ob-input", placeholder: "contato@clube.com" %>
      </div>
    </div>

    <div class="ob-field">
      <%= f.label :website, "Site", class: "ob-label" %>
      <%= f.url_field :website, class: "ob-input", placeholder: "https://seuclubepadel.com.br" %>
    </div>

    <div class="ob-field">
      <%= f.label :description, "Descrição", class: "ob-label" %>
      <%= f.text_area :description, class: "ob-input ob-textarea",
            placeholder: "Conte um pouco sobre seu clube...", rows: 3 %>
    </div>

    <div class="ob-actions">
      <%= link_to edit_onboarding_account_type_path, class: "ob-btn ob-btn--ghost" do %>
        <i class="bi bi-arrow-left"></i> Voltar
      <% end %>
      <button type="submit" class="ob-btn ob-btn--primary">
        Concluir <i class="bi bi-check-lg"></i>
      </button>
    </div>
  <% end %>
</div>
