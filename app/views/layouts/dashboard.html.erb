<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Dashboard — Padex" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "dashboard", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>(function(){var t=localStorage.getItem("padeex-theme");if(t)document.documentElement.setAttribute("data-theme",t);})()</script>
  </head>

  <body class="dashboard-body <%= controller_name %>-<%= action_name %>">
    <nav class="dash-navbar">
      <%= link_to dashboard_path do %>
        <%= image_tag "logo_padex_branco.png", alt: "PADEX", class: "dash-logo" %>
      <% end %>
      <div class="dash-navbar-center">
        <%= link_to blog_posts_path, class: "dash-navbar-link" do %>
          <i class="bi bi-journal-text"></i> Blog
        <% end %>
        <% if FeatureFlags.enabled?(:store) %>
          <%= link_to loja_path, class: "dash-navbar-link" do %>
            <i class="bi bi-bag"></i> Loja
          <% end %>
        <% end %>
      </div>
      <div class="dash-navbar-right">
        <%= render "layouts/dashboard/help" %>
        <%= render "layouts/dashboard/notifications" %>
        <%= render "shared/theme_toggle" %>
        <div class="dash-user-menu" data-controller="dropdown">
          <button class="dash-avatar-btn" data-action="click->dropdown#toggle" aria-label="Menu do usuário">
            <% avatar_profile = current_user.club? ? current_user.club_profile : current_user.user_profile %>
            <% attached = current_user.club? ? avatar_profile&.logo&.attached? : avatar_profile&.avatar&.attached? %>
            <% if attached %>
              <% img = current_user.club? ? avatar_profile.logo : avatar_profile.avatar %>
              <%= image_tag img, class: "dash-avatar dash-avatar--img", alt: current_user.name %>
            <% else %>
              <div class="dash-avatar"><%= current_user.initials %></div>
            <% end %>
          </button>

          <div class="dash-dropdown" data-dropdown-target="menu">
            <div class="dash-dropdown__header">
              <p class="dash-dropdown__name"><%= current_user.name %></p>
              <p class="dash-dropdown__email"><%= current_user.email %></p>
            </div>
            <div class="dash-dropdown__divider"></div>
            <%= link_to dashboard_meu_perfil_path, class: "dash-dropdown__item" do %>
              <i class="bi bi-person-fill"></i> Meu Perfil
            <% end %>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dash-dropdown__item dash-dropdown__item--danger" do %>
              <i class="bi bi-box-arrow-right"></i> Sair
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <div class="dash-layout">
      <%= render "layouts/dashboard/sidebar" %>
      <main class="dash-content">
        <%= yield %>
      </main>
    </div>
    <%= render "shared/chat_widget" if FeatureFlags.enabled?(:smart_assistant) %>
  </body>
</html>
