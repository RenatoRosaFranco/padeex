<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Dashboard — Padeex" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "dashboard", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="dashboard-body">
    <nav class="dash-navbar">
      <%= image_tag "logo_padex_branco.png", alt: "PADEEX", class: "dash-logo" %>
      <div class="dash-user-menu">
        <span class="dash-user-name">Olá, <%= current_user.name.split.first %></span>
        <div class="dash-avatar"><%= current_user.initials %></div>
        <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete }, class: "dash-logout" %>
      </div>
    </nav>

    <main class="dash-content">
      <%= yield %>
    </main>
  </body>
</html>
