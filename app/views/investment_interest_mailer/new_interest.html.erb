<!-- Eyebrow -->
<p style="margin:0 0 12px 0;font-size:11px;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#4ade80;">
  Nova Proposta
</p>

<!-- Headline -->
<h1 style="margin:0 0 24px 0;font-size:26px;font-weight:800;text-transform:uppercase;color:#f0f4ff;line-height:1.15;">
  Proposta de Investimento Recebida
</h1>

<!-- Investor data -->
<table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px 0;">

  <tr>
    <td style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.06);">
      <p style="margin:0 0 3px 0;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#3a4255;">Nome</p>
      <p style="margin:0;font-size:15px;color:#f0f4ff;"><%= @interest.first_name %> <%= @interest.last_name %></p>
    </td>
  </tr>

  <tr>
    <td style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.06);">
      <p style="margin:0 0 3px 0;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#3a4255;">E-mail</p>
      <p style="margin:0;font-size:15px;">
        <a href="mailto:<%= @interest.email %>" style="color:#4ade80;text-decoration:none;"><%= @interest.email %></a>
      </p>
    </td>
  </tr>

  <% if @interest.phone.present? %>
  <tr>
    <td style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.06);">
      <p style="margin:0 0 3px 0;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#3a4255;">Telefone</p>
      <p style="margin:0;font-size:15px;color:#f0f4ff;"><%= @interest.phone %></p>
    </td>
  </tr>
  <% end %>

  <tr>
    <td style="padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.06);">
      <p style="margin:0 0 3px 0;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#3a4255;">Faixa de Investimento</p>
      <p style="margin:0;font-size:15px;font-weight:700;color:#4ade80;"><%= @interest.investment_range %></p>
    </td>
  </tr>

  <% if @interest.message.present? %>
  <tr>
    <td style="padding:12px 0;">
      <p style="margin:0 0 3px 0;font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#3a4255;">Mensagem</p>
      <p style="margin:0;font-size:15px;color:#8892b0;line-height:1.65;"><%= simple_format(@interest.message, style: "margin:0;font-size:15px;color:#8892b0;line-height:1.65;") %></p>
    </td>
  </tr>
  <% end %>

</table>

<!-- Reply CTA -->
<table cellpadding="0" cellspacing="0">
  <tr>
    <td style="background:linear-gradient(135deg,#3628c5,#22c55e);border-radius:8px;">
      <a href="mailto:<%= @interest.email %>?subject=Re: Proposta de Investimento PADEX"
         style="display:inline-block;padding:13px 28px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.13em;color:#ffffff;text-decoration:none;">
        Responder ao Investidor
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0 0;font-size:12px;color:#3a4255;">
  Recebido em <%= l(@interest.created_at, format: :long) rescue @interest.created_at.strftime("%d/%m/%Y às %H:%M") %>
</p>
