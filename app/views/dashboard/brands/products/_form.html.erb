<% if product.errors.any? %>
  <div class="sched-flash sched-flash--error">
    <%= product.errors.full_messages.first %>
  </div>
<% end %>

<%= form_with model: product,
      url: product.new_record? ? dashboard_brands_products_path : dashboard_brands_product_path(product),
      method: product.new_record? ? :post : :patch,
      multipart: true, class: "prod-form" do |f| %>

  <%# ── Section: Mídia ── %>
  <div class="prod-form-section">
    <div class="prod-form-section__header">
      <span class="prod-form-section__icon"><i class="bi bi-image"></i></span>
      <div>
        <h4 class="prod-form-section__title">Mídia</h4>
        <p class="prod-form-section__sub">Imagem principal exibida na vitrine</p>
      </div>
    </div>
    <div class="prod-form-section__body">
      <% if product.image.attached? %>
        <div class="prod-form-img-preview">
          <%= image_tag product.image, class: "prod-form-img-preview__img" %>
          <span class="prod-form-img-preview__label">Imagem atual — selecione uma nova para substituir</span>
        </div>
      <% end %>
      <%= f.file_field :image, class: "sched-input sched-file-input", accept: "image/png,image/jpeg,image/webp" %>
    </div>
  </div>

  <%# ── Section: Informações ── %>
  <div class="prod-form-section">
    <div class="prod-form-section__header">
      <span class="prod-form-section__icon"><i class="bi bi-tag"></i></span>
      <div>
        <h4 class="prod-form-section__title">Informações básicas</h4>
        <p class="prod-form-section__sub">Nome, preço e classificação do produto</p>
      </div>
    </div>
    <div class="prod-form-section__body prod-form-section__body--grid">
      <div class="sched-field" style="grid-column: 1 / -1;">
        <%= f.label :name, "Nome do produto", class: "sched-label" %>
        <%= f.text_field :name, class: "sched-input", placeholder: "Ex: Raquete Pro Carbon 360" %>
      </div>
      <div class="sched-field">
        <%= f.label :price_cents, "Preço (R$)", class: "sched-label" %>
        <%= f.text_field :price_cents,
              value: product.price_cents > 0 ? format("%.2f", product.price_cents / 100.0).gsub(".", ",") : "",
              class: "sched-input",
              placeholder: "0,00",
              inputmode: "decimal" %>
      </div>
      <div class="sched-field">
        <%= f.label :category, "Categoria", class: "sched-label" %>
        <%= f.select :category,
              BrandProduct::CATEGORIES.map { |c| [c.humanize, c] },
              { include_blank: "Selecione..." },
              class: "sched-input sched-select" %>
      </div>
      <div class="sched-field">
        <%= f.label :status, "Status", class: "sched-label" %>
        <%= f.select :status,
              [["Rascunho", "draft"], ["Ativo", "active"], ["Arquivado", "archived"]],
              {},
              class: "sched-input sched-select" %>
      </div>
      <div class="sched-field">
        <%= f.label :position, "Posição na vitrine", class: "sched-label" %>
        <%= f.number_field :position, class: "sched-input", min: 0, placeholder: "0" %>
      </div>
    </div>
  </div>

  <%# ── Section: Detalhes ── %>
  <div class="prod-form-section prod-form-section--last">
    <div class="prod-form-section__header">
      <span class="prod-form-section__icon"><i class="bi bi-card-text"></i></span>
      <div>
        <h4 class="prod-form-section__title">Detalhes adicionais</h4>
        <p class="prod-form-section__sub">Descrição e link externo (opcionais)</p>
      </div>
    </div>
    <div class="prod-form-section__body">
      <div class="sched-field" style="margin-bottom: 1rem;">
        <%= f.label :external_url, "Link externo", class: "sched-label" %>
        <%= f.url_field :external_url, class: "sched-input", placeholder: "https://suamarca.com.br/produto" %>
      </div>
      <div class="sched-field">
        <%= f.label :description, "Descrição", class: "sched-label" %>
        <%= f.text_area :description, class: "sched-input sched-textarea",
              placeholder: "Descreva o produto, materiais, diferenciais...", rows: 4 %>
      </div>
    </div>
  </div>

  <%# ── Actions ── %>
  <div class="prod-form-actions">
    <%= f.submit product.new_record? ? "Adicionar Produto" : "Salvar Alterações", class: "sched-btn sched-btn--primary" %>
    <%= link_to "Cancelar", dashboard_brands_products_path, class: "sched-btn sched-btn--ghost" %>
  </div>

<% end %>
