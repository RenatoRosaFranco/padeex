<% content_for :title, "Produtos — #{current_brand_profile&.brand_name || 'Minha Marca'}" %>

<div class="dash-welcome">
  <p class="dash-welcome-eyebrow">Minha Marca</p>
  <h1 class="dash-welcome-title">Vitrine de Produtos</h1>
  <p class="dash-welcome-sub">Gerencie os produtos da sua marca na plataforma.</p>
</div>

<div class="brand-products-toolbar">
  <span class="brand-products-count"><%= @pagy.count %> produto<%= @pagy.count == 1 ? "" : "s" %></span>
  <% if current_brand_profile %>
    <%= link_to new_dashboard_brands_product_path, class: "dash-btn dash-btn--primary" do %>
      <i class="bi bi-plus-lg"></i> Adicionar Produto
    <% end %>
  <% end %>
</div>

<% if @products.any? %>
  <div class="brand-products-grid">
    <% @products.each do |product| %>
      <div class="brand-product-card">
        <div class="brand-product-img-placeholder">
          <% if product.image.attached? %>
            <%= image_tag product.image, class: "brand-product-img" %>
          <% else %>
            <i class="bi bi-image"></i>
          <% end %>
        </div>

        <div class="brand-product-info">
          <span class="brand-product-category"><%= product.category&.humanize || "Sem categoria" %></span>
          <h3 class="brand-product-name"><%= product.name %></h3>
          <p class="brand-product-price"><%= product.price_brl %></p>
          <% if product.description.present? %>
            <p class="brand-product-desc"><%= truncate(product.description, length: 70) %></p>
          <% end %>
        </div>

        <div class="brand-product-actions">
          <span class="brand-product-badge brand-product-badge--<%= product.status %>">
            <%= { "active" => "Ativo", "draft" => "Rascunho", "archived" => "Arquivado" }[product.status] %>
          </span>
          <div class="brand-product-action-btns">
            <%= link_to edit_dashboard_brands_product_path(product), class: "brand-product-btn" do %>
              <i class="bi bi-pencil"></i>
            <% end %>
            <%= button_to dashboard_brands_product_path(product), method: :delete,
                  class: "brand-product-btn brand-product-btn--danger",
                  data: { turbo_confirm: "Remover \"#{product.name}\"?" } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="brand-pagination">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
<% else %>
  <div class="brand-empty-state">
    <i class="bi bi-bag-x brand-empty-state__icon"></i>
    <p class="brand-empty-state__title">Nenhum produto cadastrado</p>
    <p class="brand-empty-state__sub">Adicione seu primeiro produto para exibir na vitrine.</p>
    <% if current_brand_profile %>
      <%= link_to new_dashboard_brands_product_path, class: "dash-btn dash-btn--primary" do %>
        <i class="bi bi-plus-lg"></i> Adicionar Produto
      <% end %>
    <% end %>
  </div>
<% end %>
