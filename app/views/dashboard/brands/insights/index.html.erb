<% content_for :title, "Insights — #{current_user.brand_profile&.brand_name || 'Minha Marca'}" %>

<div class="dash-welcome">
  <p class="dash-welcome-eyebrow">Minha Marca</p>
  <h1 class="dash-welcome-title">Insights</h1>
  <p class="dash-welcome-sub">Acompanhe o desempenho da sua marca na plataforma.</p>
</div>

<div class="analytics-grid">
  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-eye-fill"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">12.430</span>
      <span class="analytics-stat-label">Visualizações da vitrine</span>
      <span class="analytics-stat-change positive">+18% vs mês anterior</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-bag-heart-fill"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">847</span>
      <span class="analytics-stat-label">Cliques em produtos</span>
      <span class="analytics-stat-change positive">+24% vs mês anterior</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-people-fill"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">3.214</span>
      <span class="analytics-stat-label">Atletas alcançados</span>
      <span class="analytics-stat-change positive">+9% vs mês anterior</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-stat">
    <div class="analytics-stat-icon"><i class="bi bi-star-fill"></i></div>
    <div class="analytics-stat-content">
      <span class="analytics-stat-value">4.8</span>
      <span class="analytics-stat-label">Avaliação média</span>
      <span class="analytics-stat-change neutral">Estável</span>
    </div>
  </div>
</div>

<div class="analytics-charts">
  <div class="analytics-card analytics-card-chart">
    <h3 class="analytics-chart-title">Visualizações por semana</h3>
    <div class="analytics-chart-mock">
      <div class="analytics-bar" style="height: 35%"></div>
      <div class="analytics-bar" style="height: 55%"></div>
      <div class="analytics-bar" style="height: 50%"></div>
      <div class="analytics-bar" style="height: 75%"></div>
      <div class="analytics-bar" style="height: 60%"></div>
      <div class="analytics-bar" style="height: 88%"></div>
      <div class="analytics-bar" style="height: 72%"></div>
    </div>
    <div class="analytics-chart-labels">
      <span>Seg</span>
      <span>Ter</span>
      <span>Qua</span>
      <span>Qui</span>
      <span>Sex</span>
      <span>Sáb</span>
      <span>Dom</span>
    </div>
  </div>

  <div class="analytics-card analytics-card-chart">
    <h3 class="analytics-chart-title">Alcance acumulado (últimos 7 dias)</h3>
    <div class="analytics-chart-mock analytics-chart-line">
      <svg viewBox="0 0 300 80" class="analytics-line-chart">
        <polyline fill="none" stroke="rgba(74, 222, 128, 0.8)" stroke-width="2"
                  points="0,70 40,62 80,50 120,45 160,38 200,28 240,20 280,14 300,10"/>
      </svg>
    </div>
  </div>
</div>

<div class="analytics-table-card analytics-card">
  <h3 class="analytics-chart-title">Produtos mais visualizados</h3>
  <table class="analytics-table">
    <thead>
      <tr>
        <th>Produto</th>
        <th>Categoria</th>
        <th>Visualizações</th>
        <th>Cliques</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>Raquete Pro Carbon 360</td><td>Raquetes</td><td>4.210</td><td>312</td></tr>
      <tr><td>Tênis React Padel</td><td>Calçados</td><td>3.180</td><td>248</td></tr>
      <tr><td>Bag Pro Tour</td><td>Acessórios</td><td>2.890</td><td>187</td></tr>
      <tr><td>Bola Premium X3</td><td>Bolas</td><td>1.540</td><td>62</td></tr>
      <tr><td>Luva Grip Comfort</td><td>Acessórios</td><td>610</td><td>38</td></tr>
    </tbody>
  </table>
</div>
