<% if instructor.errors.any? %>
  <div class="sched-flash sched-flash--error">
    <%= instructor.errors.full_messages.first %>
  </div>
<% end %>

<%= form_with model: [:dashboard, instructor], local: true, class: "sched-form",
              data: { controller: "onboarding-form" },
              html: { enctype: "multipart/form-data" } do |f| %>
  <div class="sched-form-grid">
    <div class="sched-field" style="grid-column: 1 / -1;">
      <%= f.label :photo, "Foto", class: "sched-label" %>
      <% if instructor.photo.attached? %>
        <div class="instructor-photo-preview">
          <%= image_tag instructor.photo, class: "instructor-photo-preview__img" %>
          <span class="instructor-photo-preview__label">Foto atual — selecione uma nova para substituir</span>
        </div>
      <% end %>
      <%= f.file_field :photo, class: "sched-input sched-file-input",
                       accept: "image/png,image/jpeg,image/webp" %>
    </div>

    <div class="sched-field">
      <%= f.label :name, "Nome completo", class: "sched-label" %>
      <%= f.text_field :name, class: "sched-input", placeholder: "Ex: Carlos Silva" %>
    </div>

    <div class="sched-field">
      <%= f.label :email, "Email", class: "sched-label" %>
      <%= f.email_field :email, class: "sched-input", placeholder: "email@exemplo.com" %>
    </div>

    <div class="sched-field">
      <%= f.label :phone, "Telefone", class: "sched-label" %>
      <%= f.telephone_field :phone, class: "sched-input", placeholder: "(11) 99999-9999",
                            inputmode: "numeric", data: { action: "input->onboarding-form#formatPhone" } %>
    </div>

    <div class="sched-field" style="grid-column: 1 / -1;">
      <%= f.label :description, "Descrição", class: "sched-label" %>
      <%= f.text_area :description, class: "sched-input sched-textarea",
                      placeholder: "Experiência, especialidades, certificações..." %>
    </div>

    <div class="sched-field">
      <%= f.label :internal_code, "Código interno", class: "sched-label" %>
      <%= f.text_field :internal_code, class: "sched-input", placeholder: "Ex: INST-001" %>
    </div>
  </div>

  <% if instructor.email.present? && !instructor.persisted? %>
    <p class="sched-hint">
      <i class="bi bi-info-circle"></i>
      Se o email informado pertencer a uma conta na plataforma, ela será vinculada automaticamente.
    </p>
  <% end %>

  <div class="sched-form-actions">
    <%= f.submit instructor.new_record? ? "Adicionar Instrutor" : "Salvar Alterações", class: "sched-btn sched-btn--primary" %>
    <%= link_to "Cancelar",
          instructor.new_record? ? dashboard_instructors_path : dashboard_instructor_path(instructor),
          class: "sched-btn sched-btn--ghost" %>
  </div>
<% end %>
