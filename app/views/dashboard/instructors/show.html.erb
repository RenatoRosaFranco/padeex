<div class="dash-welcome">
  <p class="dash-welcome-eyebrow"><%= link_to "Instrutores", dashboard_instructors_path, class: "back-link" %> / <%= @instructor.name %></p>
  <h1 class="dash-welcome-title"><%= @instructor.name %></h1>
</div>

<% if flash[:notice] %>
  <div class="sched-flash sched-flash--success"><%= flash[:notice] %></div>
<% end %>

<div class="analytics-card">
  <div class="instructor-profile">
    <div class="instructor-profile__avatar">
      <% if @instructor.photo.attached? %>
        <%= image_tag @instructor.photo, class: "instructor-profile__photo" %>
      <% else %>
        <span><%= @instructor.name.split.first(2).map { |w| w[0] }.join.upcase %></span>
      <% end %>
    </div>

    <div class="instructor-profile__info">
      <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
        <h2 class="instructor-profile__name"><%= @instructor.name %></h2>
        <% if @instructor.user.present? %>
          <span class="instructor-linked-badge">
            <i class="bi bi-patch-check-fill"></i> Conta vinculada
          </span>
        <% end %>
        <% if @instructor.internal_code.present? %>
          <span class="instructor-code-badge"><%= @instructor.internal_code %></span>
        <% end %>
      </div>

      <div class="tournament-detail" style="margin-bottom: 0;">
        <% if @instructor.email.present? %>
          <div class="tournament-detail-item">
            <span class="tournament-detail-label">Email</span>
            <span class="tournament-detail-value"><%= @instructor.email %></span>
          </div>
        <% end %>
        <% if @instructor.phone.present? %>
          <div class="tournament-detail-item">
            <span class="tournament-detail-label">Telefone</span>
            <span class="tournament-detail-value"><%= @instructor.phone %></span>
          </div>
        <% end %>
        <% if @instructor.user.present? %>
          <div class="tournament-detail-item">
            <span class="tournament-detail-label">Conta na plataforma</span>
            <span class="tournament-detail-value"><%= @instructor.user.name %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @instructor.description.present? %>
    <div class="instructor-description">
      <p class="tournament-detail-label" style="margin-bottom: 0.5rem;">Sobre</p>
      <p style="color: var(--px-muted); font-size: 0.9rem; line-height: 1.7;"><%= simple_format(@instructor.description) %></p>
    </div>
  <% end %>

  <div class="sched-form-actions" style="margin-top: 1.5rem;">
    <%= link_to "Editar", edit_dashboard_instructor_path(@instructor), class: "sched-btn sched-btn--ghost" %>
    <%= button_to "Remover", dashboard_instructor_path(@instructor), method: :delete,
        data: { turbo_confirm: "Remover #{@instructor.name} do clube?" },
        class: "sched-btn sched-btn--danger" %>
  </div>
</div>
