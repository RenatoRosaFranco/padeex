<div class="dash-welcome">
  <p class="dash-welcome-eyebrow">
    <%= link_to "Torneios", dashboard_tournaments_path, class: "back-link" %> /
    <%= link_to @tournament.name, dashboard_tournament_path(@tournament), class: "back-link" %> /
    <%= link_to @category.name, dashboard_tournament_category_path(@tournament, @category), class: "back-link" %> /
    Editar Jogo
  </p>
  <h1 class="dash-welcome-title">Editar Jogo</h1>
</div>

<div class="analytics-card">
  <%= render "form", tournament: @tournament, category: @category, match: @match,
        registrations: @registrations, groups: @groups, courts: @courts %>
</div>
