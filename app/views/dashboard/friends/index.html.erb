<div class="dash-welcome">
  <p class="dash-welcome-eyebrow">Padeex</p>
  <h1 class="dash-welcome-title">Amigos</h1>
</div>

<% if flash[:notice] %>
  <div class="sched-flash sched-flash--success"><%= flash[:notice] %></div>
<% end %>

<%# ── Search ───────────────────────────────────────────── %>
<div class="frnd-search">
  <%= form_with url: dashboard_friends_path, method: :get, local: true, class: "frnd-search__form" do %>
    <i class="bi bi-search frnd-search__icon"></i>
    <%= text_field_tag :q, params[:q],
          placeholder: "Buscar por nome ou @usuário...",
          class: "frnd-search__input",
          autocomplete: "off" %>
    <% if params[:tab].present? %>
      <%= hidden_field_tag :tab, params[:tab] %>
    <% end %>
  <% end %>
</div>

<%# ── Search results ──────────────────────────────────── %>
<% if @search_results %>
  <div class="frnd-search-results">
    <p class="dash-section-label" style="margin-bottom: .75rem;">
      Resultados (<%= @search_results.size %>)
    </p>
    <% if @search_results.empty? %>
      <div class="sched-empty"><i class="bi bi-person-x"></i><p>Nenhum usuário encontrado.</p></div>
    <% else %>
      <div class="frnd-list">
        <% @search_results.each do |user| %>
          <%= render "frnd_card", user: user, context: :search %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── Tabs ─────────────────────────────────────────────── %>
<div class="tnmt-tabs" data-controller="tabs" data-tabs-active-value="<%= @tab %>">

  <div class="tnmt-tabs__nav">
    <button class="tnmt-tabs__btn" data-tabs-target="tab" data-tab="seguindo"
            data-action="click->tabs#switch">
      Seguindo
      <span class="tnmt-tabs__count"><%= current_user.following.count %></span>
    </button>
    <button class="tnmt-tabs__btn" data-tabs-target="tab" data-tab="seguidores"
            data-action="click->tabs#switch">
      Seguidores
      <span class="tnmt-tabs__count"><%= current_user.followers.count %></span>
    </button>
    <button class="tnmt-tabs__btn" data-tabs-target="tab" data-tab="solicitacoes"
            data-action="click->tabs#switch">
      Solicitações
      <% if @pending_count > 0 %>
        <span class="tnmt-tabs__count frnd-tabs__count--pending"><%= @pending_count %></span>
      <% end %>
    </button>
  </div>

  <%# ── Tab: Seguindo ───────────────────────────────── %>
  <div class="tnmt-tabs__panel hidden" data-tabs-target="panel" data-tab="seguindo">
    <% if @tab == "seguindo" %>
      <% if @users.empty? %>
        <div class="sched-empty">
          <i class="bi bi-person-plus"></i>
          <p>Você ainda não segue ninguém. Use a busca acima para encontrar atletas.</p>
        </div>
      <% else %>
        <div class="frnd-list">
          <% @users.each do |user| %>
            <%= render "frnd_card", user: user, context: :following %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ── Tab: Seguidores ─────────────────────────────── %>
  <div class="tnmt-tabs__panel hidden" data-tabs-target="panel" data-tab="seguidores">
    <% if @tab == "seguidores" %>
      <% if @users.empty? %>
        <div class="sched-empty">
          <i class="bi bi-people"></i>
          <p>Você ainda não tem seguidores.</p>
        </div>
      <% else %>
        <div class="frnd-list">
          <% @users.each do |user| %>
            <%= render "frnd_card", user: user, context: :follower %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ── Tab: Solicitações ───────────────────────────── %>
  <div class="tnmt-tabs__panel hidden" data-tabs-target="panel" data-tab="solicitacoes">
    <% if @tab == "solicitacoes" %>
      <% if @requests.empty? %>
        <div class="sched-empty">
          <i class="bi bi-bell"></i>
          <p>Nenhuma solicitação pendente.</p>
        </div>
      <% else %>
        <div class="frnd-list">
          <% @requests.each do |follow| %>
            <div class="frnd-card">
              <%= link_to public_profile_path(follow.follower), class: "frnd-card__user" do %>
                <div class="frnd-card__avatar">
                  <%= follow.follower.initials %>
                </div>
                <div class="frnd-card__info">
                  <p class="frnd-card__name"><%= follow.follower.name %></p>
                  <% if follow.follower.user_profile&.username.present? %>
                    <p class="frnd-card__username">@<%= follow.follower.user_profile.username %></p>
                  <% end %>
                  <p class="frnd-card__since">
                    <i class="bi bi-clock"></i>
                    <%= time_ago_in_words(follow.created_at) %> atrás
                  </p>
                </div>
              <% end %>
              <div class="frnd-card__actions">
                <%= form_with url: dashboard_follow_path(follow), method: :patch, local: true do %>
                  <%= hidden_field_tag :accept, "1" %>
                  <%= submit_tag "Aceitar", class: "frnd-btn frnd-btn--accept" %>
                <% end %>
                <%= form_with url: dashboard_follow_path(follow), method: :patch, local: true do %>
                  <%= submit_tag "Recusar", class: "frnd-btn frnd-btn--reject" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

</div>
