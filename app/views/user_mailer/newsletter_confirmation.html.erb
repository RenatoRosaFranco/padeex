<!-- Eyebrow -->
<p style="margin:0 0 12px 0;font-size:11px;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#4ade80;">
  Newsletter
</p>

<!-- Headline -->
<h1 style="margin:0 0 16px 0;font-size:28px;font-weight:800;text-transform:uppercase;letter-spacing:-0.01em;color:#f0f4ff;line-height:1.15;">
  Você está dentro,<br>
  <span style="color:#4ade80;"><%= @user.name.split.first %>!</span>
</h1>

<!-- Body -->
<p style="margin:0 0 16px 0;font-size:15px;color:#8892b0;line-height:1.7;">
  A partir de agora você receberá novidades, atualizações e conteúdos exclusivos
  do ecossistema PADEX diretamente no seu e-mail.
</p>

<p style="margin:0 0 32px 0;font-size:15px;color:#8892b0;line-height:1.7;">
  Fique de olho — tem muita coisa boa vindo por aí.
</p>

<!-- Divider -->
<hr style="border:none;border-top:1px solid rgba(255,255,255,0.07);margin:0 0 28px 0;">

<!-- CTA -->
<table cellpadding="0" cellspacing="0" style="margin:0 0 28px 0;">
  <tr>
    <td align="center" style="background:linear-gradient(135deg,#3628c5,#22c55e);border-radius:8px;">
      <a href="https://padeex.com.br"
         style="display:inline-block;padding:14px 32px;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.13em;color:#ffffff;text-decoration:none;">
        Acessar o PADEX
      </a>
    </td>
  </tr>
</table>

<!-- Unsubscribe -->
<p style="margin:0;font-size:12px;color:#3a4255;line-height:1.6;text-align:center;">
  Não quer mais receber nossos e-mails?
  <a href="<%= @unsubscribe_url %>" style="color:#4ade80;text-decoration:none;">Cancelar inscrição</a>
</p>
