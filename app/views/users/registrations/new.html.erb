<div class="auth-wrapper">
  <%= link_to root_path, class: "auth-logo-link" do %>
    <%= image_tag "logo_padex_branco.png", alt: "PADEEX", class: "auth-logo" %>
  <% end %>

  <div class="auth-card">
    <h1 class="auth-title">Criar conta</h1>
    <p class="auth-sub">Faça parte do ecossistema Padeex</p>

    <% if resource.errors.any? %>
      <div class="auth-alert-error">
        <ul>
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="auth-field">
        <%= f.label :name, "Nome completo", class: "auth-label" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name",
              class: "auth-input #{'is-invalid' if resource.errors[:name].any?}",
              placeholder: "João Silva" %>
      </div>

      <div class="auth-field">
        <%= f.label :email, "E-mail", class: "auth-label" %>
        <%= f.email_field :email, autocomplete: "email",
              class: "auth-input #{'is-invalid' if resource.errors[:email].any?}",
              placeholder: "seu@email.com" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, "Senha", class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "new-password",
              class: "auth-input #{'is-invalid' if resource.errors[:password].any?}",
              placeholder: "Mínimo 8 caracteres" %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "Confirmar senha", class: "auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "auth-input",
              placeholder: "Repita a senha" %>
      </div>

      <%= f.submit "Criar conta", class: "auth-btn" %>
    <% end %>

    <div class="auth-divider">— ou —</div>

    <div class="auth-oauth auth-oauth-row">
      <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, class: "auth-btn-oauth auth-btn-google", data: { turbo: false } do %>
        <i class="bi bi-google"></i> Google
      <% end %>
      <%= button_to user_facebook_omniauth_authorize_path, method: :post, class: "auth-btn-oauth auth-btn-facebook", data: { turbo: false } do %>
        <i class="bi bi-facebook"></i> Facebook
      <% end %>
    </div>
  </div>

  <p class="auth-footer">
    Já tem uma conta?
    <%= link_to "Entrar", new_user_session_path, class: "auth-link" %>
  </p>
</div>
