<% content_for :title, "#{@post.title} — Blog Padeex" %>
<%= render Landing::BlogNavComponent.new %>
<article class="blog-article-section">
  <div class="container">
    <div class="blog-article">
      <header class="blog-article-header">
        <p class="blog-article-date"><%= @post.published_at.strftime("%d/%m/%Y") %></p>
        <h1 class="blog-article-title"><%= @post.title %></h1>
        <% if @post.excerpt.present? %>
          <p class="blog-article-excerpt"><%= @post.excerpt %></p>
        <% end %>
      </header>
      <div class="blog-article-cover">
        <%= image_tag @post.cover_url, alt: @post.title %>
      </div>

      <div class="post-player"
           data-controller="audio-player"
           data-audio-player-text-value="<%= strip_tags(@post.content) %>">

        <button class="post-player__play"
                data-audio-player-target="playBtn"
                data-action="click->audio-player#toggle">
          <i class="bi bi-play-fill"></i>
        </button>

        <div class="post-player__meta">
          <span class="post-player__eyebrow">Ouvir</span>
          <span class="post-player__track"><%= @post.title %></span>
        </div>

        <div class="post-player__bar" data-action="click->audio-player#seek">
          <div class="post-player__bar-fill" data-audio-player-target="barFill"></div>
          <div class="post-player__bar-thumb" data-audio-player-target="barThumb"></div>
        </div>

        <div class="post-player__times">
          <span data-audio-player-target="elapsed">0:00</span>
          <span class="post-player__sep">/</span>
          <span data-audio-player-target="duration">0:00</span>
        </div>

        <button class="post-player__speed"
                data-audio-player-target="speed"
                data-action="click->audio-player#cycleSpeed">1x</button>

      </div>

      <div class="blog-article-content">
        <%= simple_format(@post.content) %>
      </div>
      <footer class="blog-article-footer">
        <%= link_to blog_posts_path, class: "blog-back-link" do %>
          <i class="bi bi-arrow-left me-2"></i>Voltar ao blog
        <% end %>
      </footer>
    </div>
  </div>
</article>
<%= render Landing::FooterComponent.new %>
