<section class="investment-form-section" data-controller="scroll-reveal">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="investment-form-card" data-scroll-reveal-target="item">
          <h2 class="investment-form-title">Invista conosco no futuro do padel</h2>
          <p class="investment-form-sub">Preencha o formulário e entraremos em contato em breve.</p>

          <div id="investment-form-cta">
            <%= render "investment_interests/form", interest: interest %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
