<section class="coming-soon-section">
  <div class="coming-soon-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="row justify-content-center text-center">
      <div class="col-lg-7 col-xl-6">
        <div class="launch-chip">
          <i class="bi bi-rocket-takeoff-fill"></i>
          Lançamento em breve
        </div>

        <h2 class="coming-soon-headline">
          Algo grande está<br>chegando ao padel.
        </h2>

        <p class="coming-soon-sub">
          Estamos construindo o maior ecossistema de padel do Brasil.
          Seja um dos primeiros a saber quando abrirmos as portas.
        </p>

        <div class="coming-soon-divider">
          <span></span>
          <%= image_tag "logo_padex_branco.png", alt: "PADEX", class: "divider-logo" %>
          <span></span>
        </div>

        <p class="coming-soon-cta-hint">
          Registre seu e-mail acima e garanta seu lugar na lista de espera.
        </p>
      </div>
    </div>
  </div>
</section>
