<nav class="padeex-navbar">
  <%= link_to root_path do %>
    <%= image_tag "logo_padex_branco.png", alt: "PADEX", class: "padeex-logo-nav" %>
  <% end %>

  <div class="navbar-nav-links">
    <%= link_to para_atletas_path, class: "navbar-nav-link" do %>
      <span class="navbar-nav-prefix">para</span>
      <span class="navbar-nav-label">Atletas</span>
    <% end %>
    <%= link_to para_clubes_path, class: "navbar-nav-link" do %>
      <span class="navbar-nav-prefix">para</span>
      <span class="navbar-nav-label">Clubes</span>
    <% end %>
    <%= link_to para_empresas_path, class: "navbar-nav-link" do %>
      <span class="navbar-nav-prefix">para</span>
      <span class="navbar-nav-label">Empresas</span>
    <% end %>
    <%= link_to para_investidores_path, class: "navbar-nav-link" do %>
      <span class="navbar-nav-prefix">para</span>
      <span class="navbar-nav-label">Investidores</span>
    <% end %>
    <%= link_to blog_posts_path, class: "navbar-nav-link" do %>
      <span class="navbar-nav-label">Blog</span>
    <% end %>
    <% if FeatureFlags.enabled?(:store) %>
      <%= link_to loja_path, class: "navbar-nav-link" do %>
        <span class="navbar-nav-label">Loja</span>
      <% end %>
    <% end %>
  </div>

  <% if Flipper.enabled?(:released_app) %>
    <div class="navbar-auth-actions">
      <%= link_to "Entrar", new_user_session_path, class: "navbar-btn-login" %>
      <%= link_to "Criar conta", new_user_registration_path, class: "navbar-btn-signup" %>
    </div>
  <% else %>
    <span class="badge-coming-soon">Em Breve</span>
  <% end %>
</nav>

<section class="hero-section">
  <div class="hero-grid-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8 text-center hero-inner">

          <%= image_tag "logo_padex_branco.png",
                alt: "PADEX",
                class: "hero-logo animate-fade-up" %>

          <h1 class="hero-headline animate-fade-up delay-1">
            O ecossistema do padel<br>
            <span class="text-accent">a um clique de distância</span>
          </h1>

          <p class="hero-sub animate-fade-up delay-2">
            Tudo que você precisa para jogar, evoluir e se conectar no padel —
            em um único lugar.
          </p>

          <div id="waitlist-cta" class="cta-form-wrapper animate-fade-up delay-3">
            <%= form_with url: "/waitlist", method: :post, class: "cta-input-group", data: { controller: "recaptcha" } do |f| %>
              <%= f.email_field :email,
                    name: "email",
                    placeholder: "Seu melhor e-mail",
                    class: "cta-input",
                    required: true,
                    autocomplete: "email" %>
              <%= f.submit "Entrar na lista", class: "cta-btn" %>
            <% end %>
          </div>

          <div class="feature-tags animate-fade-up delay-4">
            <span class="feature-tag"><i class="bi bi-lightning-charge-fill me-1"></i>Jogos</span>
            <span class="feature-tag"><i class="bi bi-bar-chart-fill me-1"></i>Rankings</span>
            <span class="feature-tag"><i class="bi bi-people-fill me-1"></i>Comunidade</span>
            <span class="feature-tag"><i class="bi bi-building-fill me-1"></i>Gestão</span>
          </div>

        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll-cue animate-fade-up delay-5" aria-hidden="true">
    <i class="bi bi-chevron-compact-down"></i>
  </div>
</section>
